{
  "name": "null-saas",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "turbo dev --filter=@null/web",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "node --experimental-strip-types --test packages/domain/src/analytics.test.ts src/entity-resolution.test.ts packages/domain/src/entity-resolution.test.ts",
    "check": "pnpm lint && pnpm typecheck && pnpm build",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:status": "supabase status",
    "supabase:types": "supabase gen types typescript --local > packages/db-types/src/database.generated.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "eslint": "^9.22.0",
    "globals": "^15.15.0",
    "prettier": "^3.5.3",
    "turbo": "^2.4.4",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.1"
  }
}
